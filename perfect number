#include <iostream>
using namespace std;
int main() {
         
         int m,n,sum=0;
         cout<<"enter numbers";
         cin>>m>>n;
         for(int i=m ; i<=n;i++){
             sum=0;
             for(int j=1;j<i;j++){
                 if(i%j==0){
                     sum=sum+j;
                 }
             } 
             if(sum==i){
                 cout<<sum;
                 
             }
         }
         return 0;
}
